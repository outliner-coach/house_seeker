{
  "name": "house-seeker",
  "private": true,
  "version": "0.1.0",
  "packageManager": "pnpm@10.18.0",
  "scripts": {
    "dev:web": "pnpm --filter @house-seeker/mobile-web dev",
    "build:web": "pnpm --filter @house-seeker/mobile-web build",
    "lint:web": "pnpm --filter @house-seeker/mobile-web lint",
    "typecheck": "pnpm -r typecheck",
    "build": "pnpm --filter @house-seeker/shared build && pnpm --filter @house-seeker/mobile-web build && pnpm --filter @house-seeker/functions build",
    "emulators": "firebase emulators:start --config prototype/firebase/firebase.json",
    "firebase:deploy:rules": "firebase deploy --only firestore:rules,storage --config prototype/firebase/firebase.json",
    "firebase:deploy:hosting": "firebase deploy --only hosting --config prototype/firebase/firebase.json"
  },
  "devDependencies": {
    "firebase-tools": "^15.5.1"
  }
}
